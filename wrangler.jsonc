{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "dna-barcode-generator",
  "compatibility_date": "2025-09-27",
  "main": ".output/server/index.mjs",
  "assets": {
    "directory": ".output/public"
  },
  "observability": {
    "enabled": true
  },
  "upload_source_maps": true,
  "compatibility_flags": [
    "nodejs_compat"
  ]
}
